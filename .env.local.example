# Optional: override the public RPC endpoints used for airdrops.
# If unset, the app falls back to the public Solana RPCs (rate-limited).
# For production / mainnet airdrops, use a dedicated RPC (Helius, QuickNode, Triton, etc.).

NEXT_PUBLIC_RPC_MAINNET=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_RPC_DEVNET=https://api.devnet.solana.com

# NOTE: The X (Twitter) API Bearer Token is NOT stored here.
# You paste it once in the app UI; it is encrypted in your browser (AES-GCM)
# and only decrypted in-memory at fetch time. See README.

# How many posts each fetch pulls from X (10-100). X bills ~$0.005 per post,
# so this is the main cost lever. The app ranks them by engagement (likes +
# reposts) and keeps the top 10. Default 50 (~$0.25/fetch). Raise toward 100
# for better coverage of the week's biggest posts, or lower to cut cost.
X_SEARCH_MAX_RESULTS=50
